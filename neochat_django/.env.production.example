DJANGO_ENV=production
DJANGO_SECRET_KEY=gere-uma-chave-longa-e-aleatoria
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=seu-dominio.com,www.seu-dominio.com

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://seu-dominio.com
CSRF_TRUSTED_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Ajuste para PostgreSQL em producao
DB_ENGINE=django.db.backends.postgresql
DB_NAME=neochat
DB_USER=neochat_user
DB_PASSWORD=troque-esta-senha
DB_HOST=127.0.0.1
DB_PORT=5432

# Necessario para Channels em producao
REDIS_URL=redis://127.0.0.1:6379/0

WHATSAPP_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
